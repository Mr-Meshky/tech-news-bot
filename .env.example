# Required — Gemini API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Required — Bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Required — Channel username (e.g. @mychannel) or numeric ID (e.g. -1001234567890)
TELEGRAM_CHANNEL_ID=@your_channel_username

# Optional — Comma-separated public Telegram channel usernames to read from via RSSHub
# Example: TELEGRAM_CHANNELS=techcrunchio,verge,wired
TELEGRAM_CHANNELS=

# Optional — Comma-separated subreddits (defaults: technology,programming,artificial,gadgets)
REDDIT_SUBREDDITS=

# Optional — Comma-separated X (Twitter) usernames to read via Nitter RSS
# X's free API doesn't allow reading, so a live Nitter instance is required.
X_ACCOUNTS=
NITTER_BASE=https://nitter.net
